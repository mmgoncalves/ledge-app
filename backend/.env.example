# ─── Banco de dados ───────────────────────────────────────────────────────────
POSTGRES_USER=ledge
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ledge_db
# Use localhost para migrations e ferramentas locais (prisma migrate, prisma studio)
# O docker-compose sobrescreve DATABASE_URL com o hostname "postgres" para o container da api
DATABASE_URL="postgresql://ledge:changeme@localhost:5432/ledge_db"

# ─── API ──────────────────────────────────────────────────────────────────────
API_PORT=3000
NODE_ENV=production

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=changeme-use-a-long-random-string
JWT_EXPIRES_IN=7d
